<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.movieWorld.mapper.GenreMapper">

	<!-- 장르(genres) 테이블 매핑 -->
    <resultMap id="GenreResultMap" type="com.movieWorld.domain.Genre">
        <id column="id" property="id"/>
        <result column="api_id" property="apiId"/>
        <result column="name" property="name"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 장르 등록 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO genres (api_id, name)
        VALUES (#{apiId}, #{name})
    </insert>

    <!-- 장르 ID로 조회 -->
    <select id="findById" resultMap="GenreResultMap">
        SELECT id, api_id, name, created_at
        FROM genres
        WHERE id = #{id}
    </select>

    <!-- API 장르 ID로 조회 (동기화 시 중복 확인용) -->
    <select id="findByApiId" resultMap="GenreResultMap">
        SELECT id, api_id, name, created_at
        FROM genres
        WHERE api_id = #{apiId}
    </select>

    <!-- 영화 ID로 해당 영화의 장르 목록 조회 (movie_genres JOIN) -->
    <select id="findByMovieId" resultMap="GenreResultMap">
        SELECT g.id, g.api_id, g.name, g.created_at
        FROM genres g
        INNER JOIN movie_genres mg ON g.id = mg.genre_id
        WHERE mg.movie_id = #{movieId}
        ORDER BY g.name
    </select>

</mapper>