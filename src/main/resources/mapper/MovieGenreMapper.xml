<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.movieWorld.mapper.MovieGenreMapper">

	<!-- 영화-장르(movie_genres) 테이블 매핑 -->
    <resultMap id="MovieGenreResultMap" type="com.movieWorld.domain.MovieGenre">
        <id column="id" property="id"/>
        <result column="movie_id" property="movieId"/>
        <result column="genre_id" property="genreId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 영화-장르 매핑 등록 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO movie_genres (movie_id, genre_id)
        VALUES (#{movieId}, #{genreId})
    </insert>

    <!-- 영화 ID로 해당 영화의 장르 매핑 전체 삭제 (동기화 시 재등록 전 정리용) -->
    <delete id="deleteByMovieId">
        DELETE FROM movie_genres
        WHERE movie_id = #{movieId}
    </delete>

    <!-- 영화 ID로 장르 매핑 목록 조회 -->
    <select id="findByMovieId" resultMap="MovieGenreResultMap">
        SELECT id, movie_id, genre_id, created_at
        FROM movie_genres
        WHERE movie_id = #{movieId}
    </select>

</mapper>